.leaderboard-page {
  padding-bottom: 16rpx;
}

.head-card {
  padding: 16rpx;
}

.title {
  font-size: 32rpx;
  color: #3d3d3d;
  font-weight: 600;
}

.desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #909090;
}

.row-card {
  margin-top: 10rpx;
  padding: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.row-card.mine {
  border: 1rpx solid #8dc8a1;
}

.left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.rank {
  width: 44rpx;
  text-align: center;
  font-size: 26rpx;
  color: #5f5f5f;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #efefef;
}

.name {
  margin-left: 10rpx;
  font-size: 28rpx;
  color: #444;
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.score {
  font-size: 30rpx;
  color: #4f9a69;
}

.meta {
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #8f8f8f;
}

.empty-card {
  margin-top: 10rpx;
  padding: 20rpx;
}
