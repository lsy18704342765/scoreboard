.mine-page {
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.profile {
  min-height: 120rpx;
  display: flex;
  align-items: center;
  padding: 14rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 10rpx;
  background: #ededed;
}

.profile-text {
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.name {
  font-size: 36rpx;
  color: #343434;
}

.id-text {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #888;
}

.edit-btn {
  width: 160rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border-radius: 6rpx;
  background: #58b86f;
  color: #fff;
  padding: 0;
}

.profile-actions {
  margin-left: auto;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.edit-avatar-btn {
  background: #7aa9d6;
}

.login-box {
  width: 100%;
}

.login-btn {
  width: 100%;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  font-size: 26rpx;
}

.login-input {
  height: 64rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 12rpx;
  margin-bottom: 10rpx;
  background: #fafafa;
}

.menu-group {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  padding: 10rpx 0;
}

.menu-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 10rpx 0;
}

.menu-share-btn {
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 0;
  line-height: normal;
}

.menu-share-btn::after {
  border: none;
}

.menu-icon {
  font-size: 36rpx;
}

.menu-text {
  margin-top: 8rpx;
  font-size: 25rpx;
  color: #5f5f5f;
}

.font-row {
  margin-top: 10rpx;
  padding: 16rpx;
  display: flex;
  align-items: center;
}

.font-icon {
  font-size: 36rpx;
  color: #7c7c7c;
}

.font-text {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: #666;
}

.mine-page.font-small .name {
  font-size: 32rpx;
}

.mine-page.font-small .menu-text {
  font-size: 22rpx;
}

.mine-page.font-small .font-text {
  font-size: 24rpx;
}

.mine-page.font-large .name {
  font-size: 40rpx;
}

.mine-page.font-large .menu-text {
  font-size: 29rpx;
}

.mine-page.font-large .font-text {
  font-size: 32rpx;
}
